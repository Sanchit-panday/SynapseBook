<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SynapseBook</title>
    @* <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" /> *@
    <link rel="stylesheet" href="~/css/main.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/main.css" asp-append-version="true" />

    @* <link rel="stylesheet" href="~/SynapseBook.styles.css" asp-append-version="true" /> *@
</head>
<body>
    <header class="p-3 inline-flex justify-center items-center border-bottom bg-[#232b2b] w-full text-xl font-semibold">
        <div class="text-white">
            <a class="" asp-area="" asp-controller="Home" asp-action="Index">SynapseBook</a>            
        </div>
    </header>
    <div class="max-w-4xl lg:max-w-5xl mx-auto px-4 py-8 border-1 border-dashed border-gray-500 min-h-170">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="text-gray-700 mb-8">
        <div class="container">
            &copy; 2025 - SynapseBook - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
