@{
    ViewData["Title"] = "Home Page";
}
@model List<SynapseBook.Models.Notes>

<div id="notes" class="gap-y-3 gap-x-3 flex flex-row flex-wrap justify-center">

    @if (Model != null && Model.Any())
    {
        @foreach (var note in Model)
        {
            <div id="note" class="bg-card w-full sm:w-1/2 md:w-1/3 lg:w-1/4 min-h-10 rounded-md shadow-sm border flex flex-col p-3">
                <div id="title" class="text-xl font-semibold">@note.Title</div>
                @if (!string.IsNullOrEmpty(@note.Description))
                {
                    <div id="seperator" class="border"></div>
                }
                <div id="content" class="text-base min-h-15">@note.Description</div>
            </div>
        }
    }
    else
    {
        <div id="note" class="w-full sm:w-1/2 md:w-1/3 lg:w-1/4 min-h-10  bg-red-100 border-dashed border-3 border-gray-500 flex flex-col">
            <div id="title">No notes found</div>
        </div>
    }
</div>